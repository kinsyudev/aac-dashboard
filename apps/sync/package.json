{
  "name": "@acme/sync",
  "private": true,
  "type": "module",
  "scripts": {
    "build-static-api-cache": "pnpm with-env tsx src/build-static-api-cache.ts",
    "sync-items": "pnpm with-env tsx src/sync-items.ts",
    "sync-items:full-refresh": "pnpm with-env tsx src/sync-items.ts --full-refresh",
    "sync-prices": "pnpm with-env tsx src/sync-prices.ts",
    "sync-prices:backfill": "pnpm with-env tsx src/sync-prices-backfill.ts",
    "classify-proficiencies": "pnpm with-env tsx src/classify-proficiencies.ts",
    "fix-handicraft-lunagems": "pnpm with-env tsx src/fix-handicraft-lunagems.ts",
    "regenerate-shopping-lists": "pnpm with-env tsx src/regenerate-shopping-lists.ts",
    "with-env": "dotenv -e ../../.env --",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --flag unstable_native_nodejs_ts_config"
  },
  "dependencies": {
    "@acme/db": "workspace:*",
    "@anthropic-ai/sdk": "^0.86.0"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:"
  }
}
